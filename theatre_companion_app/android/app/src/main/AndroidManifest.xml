<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════════════════════════════════════════════════════
         BLE-Berechtigungen (Bluetooth Low Energy / StageSync Mesh)
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Legacy BLE-Zugriff (Android ≤ 11 / API ≤ 30) -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />

    <!-- Standort-Berechtigung für BLE-Scan (Android 6–11 / API 23–30).
         Hinweis: permission_handler fordert ACCESS_FINE_LOCATION für API 23–30
         an; auf API 31+ mit BLUETOOTH_SCAN/neverForLocation nicht benötigt. -->
    <uses-permission
        android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.ACCESS_COARSE_LOCATION"
        android:maxSdkVersion="30" />

    <!-- Android 12+ (API 31+) explizite BLE-Berechtigungen.
         neverForLocation: Scan erfolgt NICHT zur Standortbestimmung.
         → Kein ACCESS_FINE_LOCATION-Fallback auf neueren Geräten erforderlich.
         → Vermeidet sensitiven Location-Permission-Dialog im Play Store. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="31" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="31" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADVERTISE"
        tools:targetApi="31" />

    <!-- ═══════════════════════════════════════════════════════════════════
         Netzwerk-Berechtigungen (WebSocket / Server-Gateway)
         ═══════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- •••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••
         Mikrofon (Talkback)
         ••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••• -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <!-- •••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••
         Kamera-Berechtigung (QR-Code / Barcode-Scanner)
         ••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••• -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- ═══════════════════════════════════════════════════════════════════
         Background / Wake (BLE-Mesh im Hintergrund halten)
         ═══════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Foreground Service Typen (Android 14+) -->
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"
        tools:targetApi="34" />
    <!-- MEDIA_PLAYBACK: hält Audio-Node aktiv wenn App im Hintergrund -->
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
        tools:targetApi="34" />
    <!-- DATA_SYNC: hält gRPC-Streams aktiv wenn App im Hintergrund -->
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        tools:targetApi="34" />
    <!-- Batterieoptimierung deaktivieren (Nutzer muss explizit zustimmen) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- ═══════════════════════════════════════════════════════════════════
         Hardware-Feature-Deklaration
         ═══════════════════════════════════════════════════════════════════ -->
    <!-- required="false": Tablets ohne BLE sollen die App auch installieren
         können – sie laufen dann im WebSocket-only-Modus (StubBleService).
         required="true" hätte die App im Play Store für BLE-lose Tablets
         und Chromebooks ausgeschlossen. -->
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="false" />

    <application
        android:label="StageSync"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Foreground Service: hält gRPC + Audio im Hintergrund aktiv -->
        <service
            android:name=".StageSyncForegroundService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback|dataSync|connectedDevice" />

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
